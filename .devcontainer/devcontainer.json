{
  "name": "VERS Development",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.9-bullseye",
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit Cloud Host",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python"
      ]
    }
  }
}
