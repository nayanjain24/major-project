# ===========================================================================
# VERS Environment Configuration
# ===========================================================================
# Copy this file to .env and customise values for your deployment.
# Do NOT commit .env to version control.

# --- Security ---
# API key for protecting FastAPI endpoints. Auto-generated if omitted.
# VERS_API_KEY=your-secret-api-key-here

# --- Logging ---
# Set log verbosity: DEBUG, INFO, WARNING, ERROR
VERS_LOG_LEVEL=INFO

# --- Notification Channels ---
# Comma-separated list of active channels: tts,sms,email
VERS_NOTIFY_CHANNELS=tts

# --- SMS Mock Configuration ---
# VERS_SMS_RECIPIENT=+91-9999999999

# --- Email Mock Configuration ---
# VERS_EMAIL_RECIPIENT=admin@emergency.local

# --- Fusion Weights ---
# Override the default 60/40 gesture/emotion weighting
# VERS_FUSION_W_GESTURE=0.60
# VERS_FUSION_W_EMOTION=0.40

# --- Camera ---
# Camera device index (0 = default webcam)
VERS_CAMERA_INDEX=0
# Capture resolution
VERS_CAPTURE_WIDTH=960
VERS_CAPTURE_HEIGHT=540

# --- Server Ports ---
VERS_API_PORT=8000
VERS_DASHBOARD_PORT=8501

# --- Edge Deployment ---
# Set to "onnx" to use ONNX Runtime inference instead of sklearn
# VERS_INFERENCE_BACKEND=sklearn
